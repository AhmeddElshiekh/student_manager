rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // A function to check if the user is the owner of a document.
    function isUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // A signed-in user can read user data (for login, search, etc.)
      allow read: if request.auth != null; 
      
      // A user can only create their own user document
      allow create: if isUser(userId);

      // Only the owner of the account can update or delete it
      allow update, delete: if isUser(userId);
    }

    // You can add rules for other collections here
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /backups/{userId}/{docId=**} {
       allow read, write, delete: if isUser(userId);
    }
  }
}